@model IEnumerable<Projectapp.Models.ApplicationUser>
@{
    Layout = null;
    var selectedRole = ViewBag.SelectedRole as string ?? "Student";
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #121212;
            color: white;
            font-family: sans-serif;
            padding: 40px;
        }

        .main-card {
            background-color: #2c2c2c;
            border-radius: 25px;
            padding: 30px;
        }

        .header-section {
            background-color: #444;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .user-item {
            background-color: #b0b0b0;
            color: black;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 15px;
            position: relative;
        }

        .btn-purple {
            background-color: #5e4bb6;
            color: white;
            border-radius: 15px;
            border: none;
        }

        .tab-btn {
            background-color: #4b3b9b;
            color: white;
            border-radius: 15px;
            padding: 8px 25px;
            border: none;
            margin-right: 10px;
            opacity: 0.6;
            text-decoration: none;
            display: inline-block;
        }

        .tab-active {
            opacity: 1;
            border: 2px solid white;
        }

        .search-bar {
            background-color: #b0b0b0;
            border-radius: 15px;
            border: none;
            padding: 5px 20px;
            width: 150px;
        }

        .empty-state {
            background-color: #444;
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            border: 2px dashed #666;
        }
    </style>
</head>
<body>
    <div class="main-card">
        <div class="header-section">
            <h2 class="mb-3"><a href="/Admin/Dashboard" style="color: white; text-decoration: none;">&lt; Manage Accounts</a></h2>
            <p class="text-secondary">@DateTime.Now.ToString("yyyy.MM.dd")</p>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex">
                <a href="?role=Student" class="tab-btn @(selectedRole == "Student" ? "tab-active" : "")">Students</a>
                <a href="?role=Supervisor" class="tab-btn @(selectedRole == "Supervisor" ? "tab-active" : "")">Supervisor</a>
            </div>
            <button class="btn btn-sm" style="background-color: #4b3b9b; color: white; border-radius: 15px; padding: 5px 20px;">Filter ▼</button>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <input type="text" class="search-bar" placeholder="Search">
            <button class="btn btn-purple px-4" data-bs-toggle="modal" data-bs-target="#createModal">Create Account</button>
        </div>

        @if (Model != null && Model.Any())
        {
            @foreach (var user in Model)
            {
                <div class="user-item">
                    @if (user.Role == "Student")
                    {
                        <p class="m-0"><strong>Student Name:</strong> @user.FullName</p>
                        <p class="m-0 text-dark">Index Number: @user.IndexNumber</p>
                        <p class="m-0 text-dark">Batch: @user.Batch</p>
                    }
                    else
                    {
                        <p class="m-0"><strong>Supervisor Name:</strong> @user.FullName</p>
                        <p class="m-0 text-dark">Academic ID: @user.AcademicId</p>
                        <p class="m-0 text-dark">Faculty: @user.Faculty</p>
                    }
                    <p class="m-0 text-dark">Degree: @user.Degree</p>
                    <button class="btn btn-purple btn-sm" style="position: absolute; right: 20px; bottom: 20px;">Remove</button>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <h4>No @selectedRole accounts found.</h4>
                <p class="text-secondary">Click "Create Account" to add the first one!</p>
            </div>
        }
    </div>

    @* --- MODAL SECTION --- *@
    <div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: #2c2c2c; color: white; border-radius: 25px;">
                <div class="modal-header" style="border-bottom: 1px solid #444;">
                    <h5 class="modal-title" id="createModalLabel">Create New Account</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CreateAccount" method="post">
                    <div class="modal-body">
                        @* Full Name - Restored *@
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="FullName" class="form-control shadow-none" style="background-color: #b0b0b0; border-radius: 10px;" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Role</label>
                            <select name="Role" id="roleSelect" class="form-select shadow-none" style="background-color: #b0b0b0; border-radius: 10px;">
                                <option value="Student">Student</option>
                                <option value="Supervisor">Supervisor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="Email" class="form-control shadow-none" style="background-color: #b0b0b0; border-radius: 10px;" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input type="password" name="PasswordHash" class="form-control shadow-none" style="background-color: #b0b0b0; border-radius: 10px;" required>
                        </div>

                        @* Dynamic ID field replacing Degree/Faculty *@
                        <div class="mb-3">
                            <label class="form-label" id="idLabel">Index Number</label>
                            <input type="text" id="idInput" name="IndexNumber" class="form-control shadow-none" style="background-color: #b0b0b0; border-radius: 10px;" required>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid #444;">
                        <button type="submit" class="btn btn-purple px-5">Save Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleSelect = document.getElementById('roleSelect');
            const idLabel = document.getElementById('idLabel');
            const idInput = document.getElementById('idInput');

            roleSelect.addEventListener('change', function () {
                if (this.value === 'Student') {
                    idLabel.innerText = 'Index Number';
                    idInput.setAttribute('name', 'IndexNumber');
                } else {
                    idLabel.innerText = 'Academic ID';
                    idInput.setAttribute('name', 'AcademicId');
                }
            });
        });
    </script>
</body>
</html>