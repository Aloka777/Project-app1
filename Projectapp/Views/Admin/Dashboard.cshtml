@model IEnumerable<Projectapp.Models.ProjectProposal>
@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #121212;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .btn-purple {
            background-color: #5e4bb6;
            color: white;
            border-radius: 20px;
            transition: all 0.3s ease;
        }

            .btn-purple:hover {
                opacity: 0.8;
                color: white;
            }

        .project-card {
            background-color: #2c2c2c;
            border-radius: 20px;
            border: none;
            color: white;
            margin-bottom: 20px;
        }

        /* Side Nav Styling */
        .faculty-sidebar {
            background-color: #b0b0b0;
            color: black;
            border-radius: 25px;
            padding: 25px;
        }

        .faculty-btn {
            background-color: #5e4bb6;
            color: white;
            border-radius: 12px;
            padding: 12px;
            text-align: left;
            width: 100%;
            border: none;
            margin-bottom: 10px;
        }

        /* Filter Dropdown Styling */
        .dropdown-menu {
            background-color: #d1d1d1;
            border-radius: 20px;
            width: 280px;
            border: none;
            box-shadow: 0px 10px 30px rgba(0,0,0,0.5);
            padding: 20px;
        }

        .form-select, .form-control {
            background-color: #a0a0a0;
            border: none;
            border-radius: 12px;
            color: #333;
        }
    </style>
</head>
<body>

    <div class="container-fluid p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="color: #6a5acd; font-weight: bold;">Admin</h2>
            <a href="/Admin/ManageAccounts" class="btn btn-purple px-4">Manage Accounts</a>
        </div>

        <div class="p-5 mb-4" style="background-color: #2c2c2c; border-radius: 20px;">
            <h1 class="display-3 fw-bold m-0">Welcome</h1>
            <p class="text-secondary mt-2">@DateTime.Now.ToString("yyyy.MM.dd")</p>
        </div>

        <div class="row">
            <div class="col-lg-8">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="d-flex gap-2">
                        <button class="btn btn-purple btn-sm px-4">All</button>
                        <button class="btn btn-sm px-3" style="background-color: #3d3d3d; color: white; border-radius: 15px;">Unmatched</button>
                        <button class="btn btn-sm px-3" style="background-color: #3d3d3d; color: white; border-radius: 15px;">Matched</button>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-purple btn-sm px-4 dropdown-toggle" type="button" id="filterBtn" data-bs-toggle="dropdown" aria-expanded="false">
                            Filter
                        </button>
                        <div class="dropdown-menu dropdown-menu-end" aria-labelledby="filterBtn">
                            <form asp-action="Dashboard" asp-controller="Admin" method="get">
                                <h6 class="fw-bold mb-3">Filter by</h6>

                                <label class="small fw-bold mb-1">Sort By</label>
                                <select name="sortBy" class="form-select mb-3">
                                    <option value="date">Date</option>
                                    <option value="name">Name</option>
                                </select>

                                <label class="small fw-bold mb-1">Faculty</label>
                                <select name="faculty" id="facultySelect" class="form-select mb-3">
                                    <option value="All">All</option>
                                    <option value="Computing">Computing</option>
                                    <option value="Business">Business</option>
                                    <option value="Engineering">Engineering</option>
                                    <option value="Science">Science</option>
                                </select>

                                <label class="small fw-bold mb-1">Subject</label>
                                <select name="subject" id="subjectSelect" class="form-select mb-4">
                                    <option value="">-</option>
                                </select>

                                <button type="submit" class="btn btn-purple w-100 fw-bold">Apply Filter</button>
                            </form>
                        </div>
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    @foreach (var project in Model)
                    {
                        <div class="card project-card">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h4 class="fw-bold mb-1">@project.Title</h4>
                                        <p class="text-secondary mb-2">Group: @project.GroupName | Category: @project.Category</p>
                                        <span class="badge @(project.Status == "Matched" ? "bg-success" : "bg-warning text-dark")" style="border-radius: 8px; padding: 6px 12px;">
                                            @project.Status
                                        </span>
                                    </div>
                                    <div class="text-end">
                                        <p class="small text-secondary mb-1">@project.Faculty</p>
                                        <p class="small text-secondary mb-3">@project.DateCreated.ToString("yyyy.MM.dd")</p>
                                        <a href="/Admin/ProjectDetails/@project.Id" class="btn btn-purple btn-sm px-4">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center p-5" style="background-color: #2c2c2c; border-radius: 20px; border: 2px dashed #444;">
                        <p class="text-secondary fs-5 m-0">No projects found matching this criteria.</p>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="faculty-sidebar">
                    <h4 class="fw-bold mb-4">Faculty</h4>

                    <div class="d-grid">
                        <button class="faculty-btn" type="button" data-bs-toggle="collapse" data-bs-target="#busList">
                            Business <span class="float-end">▼</span>
                        </button>
                        <div class="collapse mb-3 ps-3 text-dark small" id="busList">
                            • Business Analytics<br>• Tourism & Events<br>• Accounting & Finance<br>• HR Management
                        </div>

                        <button class="faculty-btn" type="button" data-bs-toggle="collapse" data-bs-target="#compList">
                            Computing <span class="float-end">▼</span>
                        </button>
                        <div class="collapse mb-3 ps-3 text-dark small" id="compList">
                            • Computer Science<br>• Software Engineering<br>• Data Science<br>• Cyber Security
                        </div>

                        <button class="faculty-btn" type="button" data-bs-toggle="collapse" data-bs-target="#engList">
                            Engineering <span class="float-end">▼</span>
                        </button>
                        <div class="collapse mb-3 ps-3 text-dark small" id="engList">
                            • Mechatronic Engineering<br>• Electrical Engineering<br>• Interior Design
                        </div>

                        <button class="faculty-btn" type="button" data-bs-toggle="collapse" data-bs-target="#sciList">
                            Science <span class="float-end">▼</span>
                        </button>
                        <div class="collapse mb-3 ps-3 text-dark small" id="sciList">
                            • Psychology<br>• Biomedical Science
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const subjects = {
            'Computing': ['Information Technology', 'Computer Science', 'Software Engineering', 'Data Science', 'Artificial Intelligence'],
            'Business': ['Business Analytics', 'Accounting and Finance', 'Project Management', 'Human Resource Management'],
            'Engineering': ['Mechatronic Engineering', 'Electrical Engineering', 'Interior Design'],
            'Science': ['Psychology', 'Biomedical Science']
        };

        const facultySelect = document.getElementById('facultySelect');
        const subjectSelect = document.getElementById('subjectSelect');

        facultySelect.addEventListener('change', function() {
            const selected = this.value;
            subjectSelect.innerHTML = '<option value="">-</option>';

            if (subjects[selected]) {
                subjects[selected].forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s;
                    opt.innerHTML = s;
                    subjectSelect.appendChild(opt);
                });
            }
        });
    </script>
</body>
</html>