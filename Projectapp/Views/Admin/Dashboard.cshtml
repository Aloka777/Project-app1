@model IEnumerable<Projectapp.Models.ProjectProposal>
@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
    // This safety check prevents crashes if the database tables are empty
    var faculties = (ViewBag.Faculties as IEnumerable<Projectapp.Models.Faculty>) ?? new List<Projectapp.Models.Faculty>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #121212; color: white; font-family: 'Segoe UI', sans-serif; }
        .btn-purple { background-color: #5e4bb6; color: white; border-radius: 20px; transition: all 0.3s ease; border: none; }
        .btn-purple:hover { opacity: 0.8; color: white; }
        .project-card { background-color: #2c2c2c; border-radius: 20px; border: none; color: white; margin-bottom: 20px; }
        .faculty-sidebar { background-color: #b0b0b0; color: black; border-radius: 25px; padding: 25px; }
        .faculty-btn { background-color: #5e4bb6; color: white; border-radius: 12px; padding: 12px; text-align: left; width: 100%; border: none; margin-bottom: 10px; font-weight: bold; }
        .dropdown-menu { background-color: #d1d1d1; border-radius: 20px; width: 280px; border: none; box-shadow: 0px 10px 30px rgba(0,0,0,0.5); padding: 20px; }
        .form-select, .form-control { background-color: #a0a0a0; border: none; border-radius: 12px; color: #333; }
        .status-btn { border-radius: 15px; background-color: #3d3d3d; color: white; border: none; padding: 5px 20px; text-decoration: none; font-size: 0.85rem; }
        .status-btn.active { background-color: #5e4bb6; }
        .area-link { display: block; color: #333; text-decoration: none; padding: 4px 0; border-bottom: 1px dashed #999; }
        .area-link:hover { color: #5e4bb6; font-weight: bold; }
    </style>
</head>
<body>

    <div class="container-fluid p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="color: #6a5acd; font-weight: bold;">Admin</h2>
            <a href="/Admin/ManageAccounts" class="btn btn-purple px-4">Manage Accounts</a>
        </div>

        <div class="p-5 mb-4" style="background-color: #2c2c2c; border-radius: 20px;">
            <h1 class="display-3 fw-bold m-0">Welcome</h1>
            <p class="text-secondary mt-2">@DateTime.Now.ToString("yyyy.MM.dd")</p>
        </div>

        <div class="row">
            <div class="col-lg-8">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("Dashboard", new { status = "All" })" class="status-btn @(Context.Request.Query["status"] == "All" || string.IsNullOrEmpty(Context.Request.Query["status"]) ? "active" : "")">All</a>
                        <a href="@Url.Action("Dashboard", new { status = "Unmatched" })" class="status-btn @(Context.Request.Query["status"] == "Unmatched" ? "active" : "")">Unmatched</a>
                        <a href="@Url.Action("Dashboard", new { status = "Matched" })" class="status-btn @(Context.Request.Query["status"] == "Matched" ? "active" : "")">Matched</a>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-purple btn-sm px-4 dropdown-toggle" type="button" id="filterBtn" data-bs-toggle="dropdown">
                            Filter
                        </button>
                        <div class="dropdown-menu dropdown-menu-end" aria-labelledby="filterBtn">
                            <form method="get" action="/Admin/Dashboard">
                                <h6 class="fw-bold mb-3">Filter by</h6>

                                <label class="small fw-bold mb-1">Sort By</label>
                                <select name="sortBy" class="form-select mb-3">
                                    <option value="newest">Newest First</option>
                                    <option value="name">Project Name (A-Z)</option>
                                    <option value="faculty">Faculty</option>
                                </select>

                                <label class="small fw-bold mb-1">Faculty</label>
                                <select name="facultyFilter" class="form-select mb-4">
                                    <option value="All">All Faculties</option>
                                    @foreach(var f in faculties) {
                                        <option value="@f.Name">@f.Name</option>
                                    }
                                </select>

                                <button type="submit" class="btn btn-purple w-100 fw-bold">Apply Filter</button>
                            </form>
                        </div>
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    @foreach (var project in Model)
                    {
                        <div class="card project-card">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h4 class="fw-bold mb-1">@project.Title</h4>
                                        <p class="text-secondary mb-2">Group: @project.GroupName | Category: @project.Category</p>
                                        <span class="badge @(project.SupervisorId != null ? "bg-success" : "bg-warning text-dark")">
                                            @(project.SupervisorId != null ? "Matched ✓" : "Unmatched")
                                        </span>
                                    </div>
                                    <div class="text-end">
                                        <p class="small text-secondary mb-1">@project.Faculty</p>
                                        <p class="small text-secondary mb-3">@project.DateCreated.ToString("yyyy.MM.dd")</p>
                                        <a href="/Admin/ProjectDetails/@project.Id" class="btn btn-purple btn-sm px-4">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center p-5" style="background-color: #2c2c2c; border-radius: 20px; border: 2px dashed #444;">
                        <p class="text-secondary fs-5 m-0">No projects found matching this criteria.</p>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="faculty-sidebar">
                    <h4 class="fw-bold mb-4">Faculty Management</h4>
                    <div class="d-grid">
                        @foreach(var fac in faculties) {
                            <button class="faculty-btn" type="button" data-bs-toggle="collapse" data-bs-target="#fac-@fac.Id">
                                @fac.Name <span class="float-end">▼</span>
                            </button>
                            <div class="collapse mb-3 ps-2" id="fac-@fac.Id">
                                @if(fac.ResearchAreas != null && fac.ResearchAreas.Any()) {
                                    foreach(var area in fac.ResearchAreas) {
                                        <a href="javascript:void(0)" class="area-link small" onclick="openKeywordModal(@area.Id, '@area.Name')">
                                            • @area.Name
                                        </a>
                                    }
                                } else {
                                    <p class="small text-muted ps-2">No Research Areas found.</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* KEYWORD MODAL *@
    <div class="modal fade" id="keywordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-dark" style="border-radius: 20px;">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold" id="modalTitle">Add Keyword</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Admin/AddKeyword" method="post">
                    <div class="modal-body">
                        <input type="hidden" name="researchAreaId" id="modalAreaId" />
                        <label class="small fw-bold mb-2">Keyword Name</label>
                        <input type="text" name="keywordName" class="form-control mb-3" placeholder="e.g. IoT Architecture" required style="background-color: #eee;"/>
                        <p class="text-muted small">This keyword will be stored in the MasterKeywords table linked to this Research Area.</p>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="submit" class="btn btn-purple px-4">Save Keyword</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function openKeywordModal(id, name) {
            document.getElementById('modalAreaId').value = id;
            document.getElementById('modalTitle').innerText = "Keywords for: " + name;
            var myModal = new bootstrap.Modal(document.getElementById('keywordModal'));
            myModal.show();
        }
    </script>
</body>
</html>