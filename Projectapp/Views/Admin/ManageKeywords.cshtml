@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Keywords</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #121212;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            padding: 40px;
        }

        /* Top Navigation Bar */
        .header-card {
            background-color: #616161;
            border-radius: 25px;
            padding: 35px;
            margin-bottom: 25px;
        }

        /* Main Gray Box */
        .main-section {
            background-color: #616161;
            border-radius: 30px;
            padding: 35px;
            min-height: 500px;
        }

        /* Input Container */
        .input-container {
            background-color: #9e9e9e;
            border-radius: 20px;
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .keyword-input {
            background: transparent;
            border: none;
            flex-grow: 1;
            color: #121212;
            font-size: 1.2rem;
            outline: none;
            font-weight: 500;
        }

            .keyword-input::placeholder {
                color: #444;
            }

        .btn-add {
            background-color: #5e4bb6;
            color: white;
            border-radius: 15px;
            padding: 8px 25px;
            border: none;
            font-weight: bold;
        }

        /* Purple Keyword Tags */
        .tag {
            background-color: #5e4bb6;
            color: white;
            border-radius: 18px;
            padding: 10px 22px;
            margin-right: 12px;
            display: inline-flex;
            align-items: center;
            margin-bottom: 12px;
            font-size: 1rem;
        }

            .tag .remove-btn {
                margin-left: 12px;
                cursor: pointer;
                font-weight: bold;
                font-size: 1.2rem;
            }

        /* Sidebar Faculty Styling */
        .sidebar-card {
            background-color: #9e9e9e;
            border-radius: 30px;
            padding: 30px;
            color: black;
            height: 100%;
        }

        .faculty-btn {
            background-color: #5e4bb6;
            color: white;
            border-radius: 20px;
            padding: 12px;
            width: 100%;
            border: none;
            margin-bottom: 10px;
            font-weight: bold;
            text-align: center;
        }

        .sub-list {
            font-size: 0.9rem;
            padding-left: 20px;
            margin-bottom: 20px;
            color: #1a1a1a;
            font-weight: 500;
            line-height: 1.8;
        }

        .no-style {
            color: white;
            text-decoration: none;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="header-card">
        <h2 class="fw-bold m-0">
            <a href="/Admin/Dashboard" class="no-style">&lt; <span id="facultyTitle">IOT</span></a>
        </h2>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="main-section">
                <div class="input-container">
                    <input type="text" id="kwInput" class="keyword-input" placeholder="Add Keyword">
                    <button class="btn-add" onclick="addKeyword()">+ ADD</button>
                </div>

                <div id="tagsContainer">
                    <div class="tag">Iot <span class="remove-btn" onclick="this.parentElement.remove()">×</span></div>
                    <div class="tag">circuits <span class="remove-btn" onclick="this.parentElement.remove()">×</span></div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="sidebar-card">
                <h4 class="fw-bold mb-4">Faculty</h4>

                <button class="faculty-btn" onclick="updateTitle('BUSINESS')" data-bs-toggle="collapse" data-bs-target="#busList">Business</button>
                <div class="collapse sub-list" id="busList">
                    • Business Analytics<br>• Accounting & Finance
                </div>

                <button class="faculty-btn" onclick="updateTitle('COMPUTING')" data-bs-toggle="collapse" data-bs-target="#compList">Computing</button>
                <div class="collapse show sub-list" id="compList">
                    • IoT<br>• AI<br>• Data Science<br>• Software Engineering
                </div>

                <button class="faculty-btn" onclick="updateTitle('ENGINEERING')" data-bs-toggle="collapse" data-bs-target="#engList">Engineering</button>
                <div class="collapse sub-list" id="engList">
                    • Mechatronic Engineering<br>• Electrical Systems
                </div>

                <button class="faculty-btn" onclick="updateTitle('SCIENCE')" data-bs-toggle="collapse" data-bs-target="#sciList">Science</button>
                <div class="collapse sub-list" id="sciList">
                    • Psychology<br>• Biomedical Science
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Function to change the Top Title
        function updateTitle(name) {
            document.getElementById('facultyTitle').innerText = name;
        }

        // Function to add a new tag
        function addKeyword() {
            const input = document.getElementById('kwInput');
            const container = document.getElementById('tagsContainer');

            if (input.value.trim() !== "") {
                const newTag = document.createElement('div');
                newTag.className = 'tag';
                newTag.innerHTML = input.value + ' <span class="remove-btn" onclick="this.parentElement.remove()">×</span>';
                container.appendChild(newTag);
                input.value = "";
            }
        }

        // Allow Enter key
        document.getElementById('kwInput').addEventListener("keypress", function(e) {
            if (e.key === "Enter") addKeyword();
        });
    </script>
</body>
</html>