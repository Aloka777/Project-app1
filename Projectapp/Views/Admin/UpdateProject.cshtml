@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Project</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #4a4a4a;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            padding: 20px;
        }

        /* Top Header Bar */
        .header-bar {
            background-color: #616161;
            border-radius: 20px;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        /* Main Form Container */
        .form-container {
            background-color: #616161;
            border-radius: 25px;
            padding: 40px;
        }

        .label-text {
            font-weight: 500;
            margin-bottom: 8px;
            display: block;
            color: #e0e0e0;
        }

        /* Rounded Input Styling */
        .custom-input {
            background-color: #b0b0b0;
            border: none;
            border-radius: 25px;
            padding: 12px 25px;
            width: 100%;
            margin-bottom: 25px;
            color: #121212;
            font-weight: 500;
        }

        .btn-purple {
            background-color: #5e4bb6;
            color: white;
            border-radius: 20px;
            padding: 8px 35px;
            border: none;
            font-weight: bold;
        }

        .back-link {
            color: white;
            text-decoration: none;
            font-size: 1.5rem;
            font-weight: bold;
        }

        /* Radio Buttons for Type */
        .radio-group {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 10px;
        }

        .form-check-input:checked {
            background-color: #5e4bb6;
            border-color: #5e4bb6;
        }
    </style>
</head>
<body>

    <div class="header-bar">
        <a href="/Admin/Dashboard" class="back-link">&lt; Project</a>
        <button class="btn-purple">Update</button>
    </div>

    <div class="form-container">
        <div class="row">
            <div class="col-12">
                <label class="label-text">Project Title</label>
                <input type="text" class="custom-input">

                <label class="label-text">Research Area</label>
                <input type="text" class="custom-input">

                <label class="label-text">Technical Stack</label>
                <input type="text" class="custom-input">

                <label class="label-text">Abstract</label>
                <textarea class="custom-input" style="height: 100px; border-radius: 25px;"></textarea>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <label class="label-text">Upload your Proposal</label>
                <input type="text" class="custom-input" placeholder="File path or name...">
            </div>
            <div class="col-md-6">
                <label class="label-text">Supervisor</label>
                <div class="d-flex gap-2 align-items-center">
                    <input type="text" class="custom-input" placeholder="Name:">
                    <button class="btn-purple mb-4">Reassign</button>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <label class="label-text">Type</label>
                <div class="radio-group mb-4">
                    <span>Individual</span>
                    <input class="form-check-input" type="radio" name="projType" checked>
                    <span>Group</span>
                    <input class="form-check-input" type="radio" name="projType">
                </div>
                <input type="text" class="custom-input">
            </div>
            <div class="col-md-6">
                <label class="label-text">Date Created</label>
                <input type="text" class="custom-input">
            </div>
        </div>
    </div>

</body>
</html>