@model Projectapp.Models.ProjectViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/Student/project-details.css" asp-append-version="true" />
    <style>
        .custom-input input, .custom-input textarea {
            background: transparent;
            border: none;
            outline: none;
            width: 100%;
            color: inherit;
            padding: 0 10px;
        }

        .custom-input textarea {
            height: 100%;
            resize: none;
        }

        .custom-input {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-actions {
            display: flex;
            gap: 10px;
        }

        .student-chip {
            background: #666;
            color: white;
            padding: 2px 10px;
            border-radius: 15px;
            margin: 2px;
            display: inline-block;
            font-size: 0.8rem;
        }

        #fileNameDisplay {
            font-size: 0.9rem;
            color: #555;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header-card">
            <a href="@Url.Action("Index", "Student")" class="back-link"> &lt; Project</a>
            <div class="header-actions">

                <button type="submit" form="mainForm" class="btn-purple">Save</button>

                <form asp-action="WithdrawProject" method="post">
                    <input type="hidden" name="title" value="@Model.Title" />
                    <button type="submit" class="btn-purple" style="background-color: #4a47a3;">Withdraw</button>
                </form>
            </div>
        </div>

        <form asp-action="ProjectDetails" method="post" id="mainForm" enctype="multipart/form-data">
            <input type="hidden" name="originalTitle" value="@Model.Title" />

            <div class="form-box">
                <label>Project Title</label>
                <div class="custom-input">
                    <input type="text" asp-for="Title" />
                    <b>Edit</b>
                </div>

                <label>Research Area</label>
                <div class="custom-input">
                    <input type="text" asp-for="ResearchArea" />
                    <b>v</b>
                </div>

                <label>Technical Stack</label>
                <div class="custom-input">
                    <input type="text" asp-for="TechnicalStack" />
                    <b>Edit</b>
                </div>

                <label>Abstract</label>
                <div class="custom-input" style="height: 80px;">
                    <textarea asp-for="Description"></textarea>
                    <b>Edit</b>
                </div>

                <div class="row">
                    <div class="col-6">
                        <label>Upload your Proposal</label>
                        <div class="custom-input" style="cursor: pointer;" onclick="document.getElementById('proposalFile').click()">
                            <span id="fileNameDisplay">@(string.IsNullOrEmpty(Model.ProposalFileName) ? "No file uploaded" : Model.ProposalFileName)</span>
                            <b>Edit</b>
                            <input type="file" id="proposalFile" name="proposalFile" style="display: none;" onchange="updateFileName(this)" />
                        </div>

                        <div class="mb-2 text-black" style="font-size: 0.9rem; margin-top: 10px;">
                            Type: &nbsp;
                            Individual <input type="radio" asp-for="Group" value="Individual" id="typeInd" onchange="toggleStudentInput()"> &nbsp;
                            Group <input type="radio" asp-for="Group" value="Group" id="typeGroup" onchange="toggleStudentInput()">
                        </div>

                        <div class="custom-input" style="height: 100px; flex-direction: column; align-items: flex-start;">
                            <div id="studentList" class="w-100" style="flex-grow: 1; overflow-y: auto;"></div>
                            <div id="studentInputArea" style="display: none; width: 100%;">
                                <input type="text" id="studentName" placeholder="Add member..." style="width: 60%; font-size: 0.8rem; border-bottom: 1px solid #ccc !important;">
                                <button type="button" onclick="addStudent()" class="btn btn-sm btn-dark" style="font-size: 0.7rem;">+ADD</button>
                            </div>
                            <b style="align-self: flex-end; cursor: pointer;">Browse</b>
                        </div>
                    </div>

                    <div class="col-6">
                        <label>Supervisor</label>
                        <div class="custom-input" style="height: 180px; flex-direction: column; align-items: flex-start; justify-content: flex-start;">
                            <span class="mb-1">Name:</span>
                            <span class="mb-1">Faculty:</span>
                            <span class="mb-1">Contact Number:</span>
                            <span>Email:</span>
                            <b style="align-self: flex-end; margin-top: auto;">Browse</b>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <script>

        function updateFileName(input) {
            const display = document.getElementById('fileNameDisplay');
            if (input.files && input.files.length > 0) {
                display.innerText = input.files[0].name;
            }
        }

        const typeGroup = document.getElementById('typeGroup');
        const inputArea = document.getElementById('studentInputArea');
        const studentList = document.getElementById('studentList');

        function toggleStudentInput() {
            if (typeGroup.checked) {
                inputArea.style.display = 'block';
            } else {
                inputArea.style.display = 'none';
                studentList.innerHTML = '';
            }
        }

        function addStudent() {
            const nameInput = document.getElementById('studentName');
            if (nameInput.value.trim() !== "") {
                const chip = document.createElement('span');
                chip.className = 'student-chip';
                chip.innerText = nameInput.value;
                studentList.appendChild(chip);
                nameInput.value = "";
            }
        }

        window.onload = toggleStudentInput;
    </script>
</body>
</html>