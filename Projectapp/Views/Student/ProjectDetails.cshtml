@model Projectapp.Models.ProjectProposal
@{
    Layout = null;
    var supervisor = ViewBag.Supervisor as Projectapp.Models.ApplicationUser;
    var areas = ViewBag.ResearchAreas as IEnumerable<Projectapp.Models.ResearchArea>;
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/Student/project-details.css" asp-append-version="true" />
    <style>
        .custom-input { position: relative; background: white; border-radius: 10px; padding: 10px; margin-bottom: 15px; border: 1px solid #ccc; }
        .custom-input input, .custom-input select, .custom-input textarea { border: none; width: 100%; outline: none; }
        .edit-tag { position: absolute; right: 10px; color: #4a47a3; font-weight: bold; font-size: 0.8rem; }
    </style>
</head>
<body>
<div class="container mt-5">
    <form asp-action="UpdateProject" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div class="header-card d-flex justify-content-between mb-4">
            <a href="@Url.Action("Index", "Student", new { email = User.Identity.Name })" class="text-white text-decoration-none"> &lt; Back to Dashboard</a>
            <div>
                <button type="submit" class="btn btn-primary me-2">Save Project</button>
                <button type="button" class="btn btn-danger">Withdraw</button>
            </div>
        </div>

        <div class="form-box bg-light p-4 rounded-4 text-dark">
            <label class="fw-bold">Project Title</label>
            <div class="custom-input">
                <input type="text" asp-for="Title" required />
                <span class="edit-tag">Edit</span>
            </div>

            <label class="fw-bold">Research Area (Filtered by Faculty)</label>
            <div class="custom-input">
                <select asp-for="ResearchAreaId">
                    @foreach(var area in areas) {
                        <option value="@area.Id" selected="@(area.Id == Model.ResearchAreaId)">@area.Name</option>
                    }
                </select>
            </div>

            <label class="fw-bold">Technical Stack</label>
            <div class="custom-input">
                <input type="text" asp-for="TechnicalStack" placeholder="C#, Flutter, SQL..." />
            </div>

            <label class="fw-bold">Abstract</label>
            <div class="custom-input">
                <textarea asp-for="Abstract" rows="3"></textarea>
            </div>

            <div class="row">
                <div class="col-6">
                    <label class="fw-bold">Proposal Document</label>
                    <div class="custom-input">
                        <input type="file" name="proposalFile" />
                    </div>
                    
                    <div class="mt-3">
                        <input type="radio" asp-for="Type" value="Individual"> Individual 
                        <input type="radio" asp-for="Type" value="Group" class="ms-3"> Group
                    </div>

                    <div id="members-area" class="mt-3">
                        <label class="small fw-bold">Team Member Student IDs</label>
                        <div id="member-inputs">
                            @if(!string.IsNullOrEmpty(Model.TeamMembers)) {
                                foreach(var id in Model.TeamMembers.Split(',')) {
                                    <input type="text" name="memberIds" value="@id" class="form-control form-control-sm mb-1" />
                                }
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-dark mt-1" onclick="addId()">+ Add Student ID</button>
                    </div>
                </div>

                <div class="col-6">
                    <label class="fw-bold">Supervisor Details</label>
                    <div class="custom-input" style="height: 180px; background-color: @(supervisor == null ? "#eee" : "white")">
                        @if(Model.Status == "Accepted" && supervisor != null) {
                            <div class="p-2">
                                <div><strong>Name:</strong> @supervisor.FullName</div>
                                <div><strong>Faculty:</strong> @supervisor.Faculty</div>
                                <div><strong>Email:</strong> @supervisor.Email</div>
                                <div class="badge bg-success mt-2">Verified Supervisor</div>
                            </div>
                        } else {
                            <div class="text-center text-muted mt-5">
                                Details hidden until a supervisor accepts.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    function addId() {
        const div = document.createElement('input');
        div.name = 'memberIds';
        div.className = 'form-control form-control-sm mb-1';
        div.placeholder = 'Student ID';
        document.getElementById('member-inputs').appendChild(div);
    }
</script>
</body>
</html>