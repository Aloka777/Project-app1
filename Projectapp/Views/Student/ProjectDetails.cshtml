@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/Student/project-details.css" asp-append-version="true" />
</head>
<body>
    <div class="container">
        <div class="header-card">
            <a href="@Url.Action("Index", "Student")" class="back-link"> &lt; Project</a>
            <div>
                <button class="btn-purple me-2">Save</button>
                <button class="btn-purple" style="background-color: #4a47a3;">Withdraw</button>
            </div>
        </div>

        <div class="form-box">
            <label>Project Title</label>
            <div class="custom-input"><span></span> <b>Edit</b></div>

            <label>Research Area</label>
            <div class="custom-input"><span></span> <b>v</b></div>

            <label>Technical Stack</label>
            <div class="custom-input"><span></span> <b>Edit</b></div>

            <label>Abstract</label>
            <div class="custom-input" style="height: 80px;"><span></span> <b>Edit</b></div>

            <div class="row">
                <div class="col-6">
                    <label>Upload your Proposal</label>
                    <div class="custom-input"><span></span> <b>Edit</b></div>
                    <div class="mb-2 text-black" style="font-size: 0.9rem;">
                        Type: &nbsp; Individual <input type="radio" name="t"> &nbsp; Group <input type="radio" name="t">
                    </div>
                    <div class="custom-input" style="height: 100px; align-items: flex-end; justify-content: flex-end;"><b>+ADD<br>Browse</b></div>
                </div>
                <div class="col-6">
                    <label>Supervisor</label>
                    <div class="custom-input" style="height: 180px; flex-direction: column; align-items: flex-start; justify-content: flex-start;">
                        <span class="mb-1">Name:</span>
                        <span class="mb-1">Faculty:</span>
                        <span class="mb-1">Contact Number:</span>
                        <span>Email:</span>
                        <b style="align-self: flex-end; margin-top: auto;">Browse</b>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>