@model Projectapp.Models.ProjectViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create Project</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/Student/create-project.css" asp-append-version="true" />
    <style>
        .custom-input input, .custom-input textarea {
            width: 100%;
            height: 100%;
            border: none;
            background: transparent;
            outline: none;
            color: inherit;
            padding: 0 10px;
        }

        .student-chip {
            background: #666;
            color: white;
            padding: 2px 10px;
            border-radius: 15px;
            margin: 2px;
            display: inline-block;
            font-size: 0.8rem;
        }

        #studentContainer {
            overflow-y: auto;
            padding: 10px;
            display: none;
        }

 
        #fileNameDisplay {
            font-size: 0.9rem;
            color: #555;
            padding-left: 10px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            width: 80%;
        }
    </style>
</head>
<body>
    <form asp-action="CreateProject" method="post" enctype="multipart/form-data">
        <div class="main-container">
            <div class="header-card shadow">
                <a href="@Url.Action("Index", "Student")" class="back-btn"> < Create Project </a>
                <button type="submit" class="btn btn-purple">Create</button>
            </div>

            <div class="form-container shadow-lg">
                <label>Project Title</label>
                <div class="custom-input"><input type="text" asp-for="Title" required /></div>

                <div class="d-flex align-items-center mb-3 px-3">
                    <span style="color: #000; font-weight: 500; margin-right: 20px;">Type</span>
                    <span class="me-3" style="color: #000;">
                        Individual <input type="radio" asp-for="Group" value="Individual" id="typeInd" class="form-check-input ms-1" checked>
                    </span>
                    <span style="color: #000;">
                        Group <input type="radio" asp-for="Group" value="Group" id="typeGroup" class="form-check-input ms-1">
                    </span>
                </div>

                <div class="custom-input d-flex flex-column align-items-end" style="height: 100px; position: relative;">
                    <div id="studentList" class="w-100 px-2" style="flex-grow: 1;"></div>
                    <div id="studentInputArea" style="display: none; width: 100%;" class="px-2">
                        <input type="text" id="studentName" placeholder="Enter Student Name..." style="width: 70%; border-bottom: 1px solid #000;">
                        <button type="button" onclick="addStudent()" class="btn btn-sm btn-dark">+ADD</button>
                    </div>
                </div>

                <label>Research Area</label>
                <div class="custom-input d-flex justify-content-end align-items-center">
                    <input type="text" asp-for="ResearchArea" />
                    <span style="font-weight: bold;">v</span>
                </div>

                <label>Technical Stack</label>
                <div class="custom-input"><input type="text" asp-for="TechnicalStack" /></div>

                <label>Abstract</label>
                <div class="custom-input" style="height: 100px;">
                    <textarea asp-for="Description"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <label>Upload your Proposal</label>
                        <div class="custom-input d-flex align-items-center justify-content-between"
                             style="height: 100px; cursor: pointer;"
                             onclick="document.getElementById('proposalFile').click()">

                            <span id="fileNameDisplay">Click to upload...</span>
                            <b class="pe-3">Edit</b>

                            <input type="file" id="proposalFile" name="proposalFile" style="display: none;" onchange="displayFileName(this)" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label>Add Keywords</label>
                        <div class="custom-input" style="height: 100px;"><input type="text" asp-for="Category" /></div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <script>
        const typeGroup = document.getElementById('typeGroup');
        const typeInd = document.getElementById('typeInd');
        const inputArea = document.getElementById('studentInputArea');
        const studentList = document.getElementById('studentList');

        function toggleStudentInput() {
            if (typeGroup.checked) {
                inputArea.style.display = 'block';
            } else {
                inputArea.style.display = 'none';
                studentList.innerHTML = '';
            }
        }

        typeGroup.addEventListener('change', toggleStudentInput);
        typeInd.addEventListener('change', toggleStudentInput);

        function addStudent() {
            const nameInput = document.getElementById('studentName');
            if (nameInput.value.trim() !== "") {
                const chip = document.createElement('span');
                chip.className = 'student-chip';
                chip.innerText = nameInput.value;
                studentList.appendChild(chip);
                nameInput.value = "";
            }
        }

        function displayFileName(input) {
            const display = document.getElementById('fileNameDisplay');
            if (input.files && input.files.length > 0) {
                display.innerText = input.files[0].name;
                display.style.color = "#000";
            } else {
                display.innerText = "Click to upload...";
                display.style.color = "#555";
            }
        }
    </script>
</body>
</html>