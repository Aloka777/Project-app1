@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create Project</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/Student/create-project.css" asp-append-version="true" />
</head>
<body>
    <div class="main-container">
        <div class="header-card shadow">
            <a href="@Url.Action("Index", "Student")" class="back-btn"> < Create Project </a>
            <button class="btn btn-purple">Create</button>
        </div>

        <div class="form-container shadow-lg">
            <label>Project Title</label>
            <div class="custom-input"></div>

            <div class="d-flex align-items-center mb-3 px-3">
                <span style="color: #000; font-weight: 500; margin-right: 20px;">Type</span>
                <span class="me-3" style="color: #000;">Individual <input type="radio" name="type" class="form-check-input ms-1"></span>
                <span style="color: #000;">Group <input type="radio" name="type" class="form-check-input ms-1"></span>
            </div>

            <div class="custom-input d-flex align-items-center justify-content-end" style="height: 100px;">
                <div class="fw-bold">+ADD</div>
            </div>

            <label>Research Area</label>
            <div class="custom-input d-flex justify-content-end align-items-center">
                <span style="font-weight: bold;">v</span>
            </div>

            <label>Technical Stack</label>
            <div class="custom-input"></div>

            <label>Abstract</label>
            <div class="custom-input" style="height: 100px;"></div>

            <div class="row">
                <div class="col-md-6">
                    <label>Upload your Proposal</label>
                    <div class="custom-input" style="height: 100px;"></div>
                </div>
                <div class="col-md-6">
                    <label>Add Keywords</label>
                    <div class="custom-input" style="height: 100px;"></div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>