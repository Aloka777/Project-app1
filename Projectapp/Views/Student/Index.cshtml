@model IEnumerable<Projectapp.Models.ProjectViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/Student/dashboard.css" asp-append-version="true" />
    <style>
        .filter-container {
            position: relative;
        }

        .filter-menu {
            display: none;
            position: absolute;
            right: 0;
            top: 45px;
            background: #888;
            border-radius: 15px;
            padding: 15px;
            width: 240px;
            z-index: 1000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .filter-item {
            color: black;
            padding: 8px 0;
            cursor: pointer;
            font-weight: 500;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .filter-item:hover {
                color: #fff;
            }

        .selected-display {
            background: #bbb;
            border-radius: 10px;
            padding: 4px 15px;
            margin-top: 5px;
            min-height: 30px;
            color: #333;
            font-size: 0.85rem;
            text-align: center;
            border: 1px solid #999;
        }

        .submenu {
            background: #aaa;
            border-radius: 10px;
            padding: 5px;
            margin-top: 5px;
            display: none;
        }

        .submenu-item {
            background: #eee;
            border-radius: 8px;
            margin: 5px 0;
            padding: 5px 10px;
            font-size: 0.9rem;
            text-align: center;
            cursor: pointer;
            color: #333;
            transition: background 0.2s;
        }

            .submenu-item:hover {
                background: #fff;
                color: #000;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="welcome-card">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="display-5">Welcome</h1>
                <a href="@Url.Action("Account", "Student")" class="btn btn-purple">Account</a>
            </div>
            <p>2026.04.17</p>
        </div>

        <div class="mb-4 d-flex justify-content-between align-items-center">
            <div>
                <a href="@Url.Action("ProjectDetails", "Student")" class="btn-purple me-2 text-decoration-none">Projects</a>
                <a href="@Url.Action("CreateProject", "Student")" class="btn-purple text-decoration-none">+ Create Project</a>
            </div>

            <div class="filter-container">
                <button class="btn-purple" onclick="toggleMenu('mainFilterMenu')">Filter &nbsp; ▾</button>

                <div id="mainFilterMenu" class="filter-menu">
                    <div class="filter-item" style="cursor: default;">Filter by ▾</div>
                    <hr class="my-1" style="border-color: #666;">

                    <div class="filter-item" onclick="toggleMenu('sortSubmenu')">sort by ></div>
                    <div id="selectedSort" class="selected-display">-</div>
                    <div id="sortSubmenu" class="submenu">
                        <div class="submenu-item" onclick="selectOption('selectedSort', 'A to Z')">A to Z</div>
                        <div class="submenu-item" onclick="selectOption('selectedSort', 'Z to A')">Z to A</div>
                        <div class="submenu-item" onclick="selectOption('selectedSort', 'New to Old')">New to Old</div>
                        <div class="submenu-item" onclick="selectOption('selectedSort', 'Old to New')">Old to New</div>
                    </div>

                    <div class="filter-item" onclick="toggleMenu('subjectSubmenu')">Subject ></div>
                    <div id="selectedSubject" class="selected-display">-</div>
                    <div id="subjectSubmenu" class="submenu">
                        <div class="submenu-item" onclick="selectOption('selectedSubject', 'IOT')">IOT</div>
                        <div class="submenu-item" onclick="selectOption('selectedSubject', 'Mobile Application')">Mobile Application</div>
                        <div class="submenu-item" onclick="selectOption('selectedSubject', 'Web Development')">Web Development</div>
                    </div>

                    <div class="filter-item" onclick="toggleMenu('typeSubmenu')">Type ></div>
                    <div id="selectedType" class="selected-display">-</div>
                    <div id="typeSubmenu" class="submenu">
                        <div class="submenu-item" onclick="selectOption('selectedType', 'Individual')">Individual</div>
                        <div class="submenu-item" onclick="selectOption('selectedType', 'Group')">Group</div>
                    </div>
                </div>
            </div>
        </div>

        <div style="background-color: #444; padding: 25px; border-radius: 30px;">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="project-card">
                        <div class="d-flex justify-content-between">
                            <strong>Project: @item.Title</strong>
                            <span class="status-badge">@item.Status</span>
                        </div>
                        <div>Group: @item.Group</div>
                        <div>Category: @item.Category</div>
                        <div class="small mt-2 text-muted">@item.Description</div>
                    </div>
                }
            }
            else
            {
                <p class="text-white text-center">No projects available.</p>
            }
        </div>
    </div>

    <script>
        function toggleMenu(menuId) {
            const menu = document.getElementById(menuId);
            const isVisible = menu.style.display === 'block';

            if (menuId === 'mainFilterMenu' && isVisible) {
                document.querySelectorAll('.submenu').forEach(s => s.style.display = 'none');
            }

            menu.style.display = isVisible ? 'none' : 'block';
        }
        function selectOption(displayId, value) {
            document.getElementById(displayId).innerText = value;
            const submenu = document.getElementById(displayId).nextElementSibling;
            if (submenu && submenu.classList.contains('submenu')) {
                submenu.style.display = 'none';
            }
        }

        window.onclick = function(event) {
            if (!event.target.matches('.btn-purple') && !event.target.closest('.filter-menu')) {
                document.getElementById('mainFilterMenu').style.display = 'none';
                document.querySelectorAll('.submenu').forEach(s => s.style.display = 'none');
            }
        }
    </script>
</body>
</html>