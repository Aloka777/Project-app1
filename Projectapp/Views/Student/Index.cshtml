@model IEnumerable<Projectapp.Models.ProjectProposal>
@{
    Layout = null;
    var student = ViewBag.Student as Projectapp.Models.ApplicationUser;
    var faculties = ViewBag.Faculties as List<Projectapp.Models.Faculty>;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Dashboard | ProjectApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        :root { --purple-primary: #6a5acd; --bg-dark: #0f0f12; --card-bg: #1a1a20; }
        body { background-color: var(--bg-dark); color: #fff; font-family: 'Inter', sans-serif; margin: 0; padding: 0; }
        
        .sidebar { 
            background: var(--card-bg); 
            border-right: 1px solid #333; 
            height: 100vh; 
            position: fixed; 
            padding: 25px; 
            width: 320px; 
            overflow-y: auto; 
        }
        
        /* Force high-visibility white for account labels */
        .sidebar label, .sidebar .small-label, .sidebar h4 {
            color: #ffffff !important;
            font-weight: 600;
            display: block;
            margin-bottom: 5px;
            font-size: 0.85rem;
        }

        .main-content { margin-left: 340px; padding: 40px; }
        .glass-card { background: var(--card-bg); border: 1px solid #2d2d35; border-radius: 16px; padding: 24px; margin-bottom: 20px; }
        
        .btn-purple { background: var(--purple-primary); color: white; border-radius: 8px; border: none; padding: 10px 20px; font-weight: 600; text-decoration: none; }
        .btn-purple:hover { background: #5849ab; color: white; }

        .form-control, .form-select { 
            background: #25252d; 
            border: 1px solid #444; 
            color: #ffffff; 
            margin-bottom: 12px;
        }
        .form-control:focus { background: #2a2a35; color: #fff; border-color: var(--purple-primary); box-shadow: none; }

        .status-badge { padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: bold; }
        .bg-pending { background: rgba(255, 193, 7, 0.1); color: #ffc107; border: 1px solid #ffc107; }
        .bg-accepted { background: rgba(40, 167, 69, 0.1); color: #28a745; border: 1px solid #28a745; }
    </style>
</head>
<body>

    <div class="sidebar">
        <h4 class="mb-4" style="color: var(--purple-primary);">My Account</h4>
        
        <form asp-action="UpdateProfile" asp-controller="Student" method="post">
            <input type="hidden" name="Id" value="@student.Id" />
            
            <label>Full Name</label>
            <input type="text" name="FullName" class="form-control" value="@student.FullName" />

            <div class="row g-2">
                <div class="col-6">
                    <label>Faculty</label>
                    <select name="Faculty" class="form-select">
                        @foreach(var f in faculties) {
                            <option value="@f.Name" selected="@(f.Name == student.Faculty)">@f.Name</option>
                        }
                    </select>
                </div>
                <div class="col-6">
                    <label>Batch</label>
                    <input type="text" name="Batch" class="form-control" value="@student.Batch" />
                </div>
            </div>

            <label>Degree</label>
            <input type="text" name="Degree" class="form-control" value="@student.Degree" />

            <label>Address</label>
            <input type="text" name="Address" class="form-control" value="@student.Address" />

            <div class="row g-2">
                <div class="col-6">
                    <label>Gender</label>
                    <select name="Gender" class="form-select">
                        <option value="Male" selected="@(student.Gender == "Male")">Male</option>
                        <option value="Female" selected="@(student.Gender == "Female")">Female</option>
                    </select>
                </div>
                <div class="col-6">
                    <label>Birthday</label>
                    <input type="date" name="Birthday" class="form-control" value="@(student.Birthday?.ToString("yyyy-MM-dd"))" />
                </div>
            </div>

            <div class="row g-2">
                <div class="col-6">
                    <label>NIC</label>
                    <input type="text" name="NIC" class="form-control" value="@student.NIC" />
                </div>
                <div class="col-6">
                    <label>Student ID</label>
                    <input type="text" name="IndexNumber" class="form-control" value="@student.IndexNumber" />
                </div>
            </div>

            <label>Email</label>
            <input type="email" name="Email" class="form-control" value="@student.Email" />

            <label>Password</label>
            <input type="password" name="PasswordHash" class="form-control" placeholder="Update Password" />

            <button type="submit" class="btn btn-purple w-100 mt-3">Update Profile</button>
        </form>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="fw-bold">Student Dashboard</h2>
            <button class="btn btn-purple" data-bs-toggle="modal" data-bs-target="#newProjectModal">Launch New Project</button>
        </div>

        @if (!Model.Any()) {
            <div class="glass-card text-center py-5">
                <p class="text-muted">No projects found. Start by creating a new proposal.</p>
            </div>
        }

        @foreach (var proj in Model) {
            <div class="glass-card d-flex">
                <div class="col-md-3 border-end border-secondary pe-4 me-4">
                    <h6 class="small text-uppercase fw-bold" style="color: var(--purple-primary);">Supervisor</h6>
                    @if (proj.Status == "Accepted" && !string.IsNullOrEmpty(proj.SupervisorId)) {
                        <p class="mb-0 fw-bold text-success">Assigned ✓</p>
                    } else {
                        <p class="text-muted italic small">Waiting for approval</p>
                    }
                </div>
                
                <div class="col-md-9">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h4 class="fw-bold mb-1">@proj.Title</h4>
                            <p class="text-muted small">@proj.ResearchArea?.Name | @proj.TechnicalStack</p>
                        </div>
                        <span class="status-badge @(proj.Status == "Accepted" ? "bg-accepted" : "bg-pending")">@proj.Status</span>
                    </div>
                    <p class="text-white-50 mt-2">@proj.Abstract</p>
                    <div class="mt-3">
                        <a href="@Url.Action("ProjectDetails", "Student", new { id = proj.Id })" class="btn btn-sm btn-outline-light">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="modal fade" id="newProjectModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0" style="background: var(--card-bg); color: #fff;">
                <div class="modal-body p-5">
                    <h3 class="fw-bold mb-4">New Project Proposal</h3>
                    <form asp-action="ManageProject" asp-controller="Student" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="StudentId" value="@student.Id" />
                        
                        <div class="mb-3">
                            <label class="text-white">Project Title</label>
                            <input type="text" name="Title" class="form-control" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="text-white">Research Area</label>
                                <select name="ResearchAreaId" class="form-select">
                                    @foreach(var ra in (ViewBag.ResearchAreas as List<Projectapp.Models.ResearchArea>)) {
                                        <option value="@ra.Id">@ra.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-white">Tech Stack</label>
                                <input type="text" name="TechnicalStack" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="text-white">Abstract</label>
                            <textarea name="Abstract" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="text-white">Upload Proposal (PDF/DOC)</label>
                            <input type="file" name="proposalFile" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-purple w-100 py-3">Submit for Review</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>