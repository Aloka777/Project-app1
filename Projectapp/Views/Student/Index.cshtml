@model IEnumerable<Projectapp.Models.ProjectViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/Student/dashboard.css" asp-append-version="true" />
    <style>
        .project-link {
            text-decoration: none;
            color: inherit;
            display: block;
            cursor: pointer;
        }

        .btn-purple.label-only {
            pointer-events: none;
            opacity: 0.9;
        }

        .filter-menu {
            background-color: #666 !important;
            border-radius: 25px !important;
            padding: 20px !important;
            min-width: 240px;
            color: white;
            border: none;
        }

        .filter-header {
            font-size: 1rem;
            margin-bottom: 15px;
            display: block;
            color: #ccc;
        }

        .filter-label {
            font-size: 0.9rem;
            margin-bottom: 5px;
            display: block;
            margin-top: 10px;
        }

        .filter-select {
            background: #999;
            border: none;
            border-radius: 20px;
            width: 100%;
            margin-bottom: 10px;
            padding: 5px 15px;
            color: #222;
            appearance: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="welcome-card">
            <div class="d-flex justify-content-between">
                <h1 class="display-5">Welcome</h1>
                <button class="btn-purple">Account</button>
            </div>
            <p>2026.04.17</p>
        </div>

        <div class="mb-4 d-flex justify-content-between">
            <div>
                <button class="btn-purple me-2 label-only">Projects</button>
                <a href="@Url.Action("CreateProject", "Student")" class="btn-purple">+ Create Project</a>
            </div>

            <div class="dropdown">
                <button class="btn-purple dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    Filter by &nbsp; ▾
                </button>
                <div class="dropdown-menu filter-menu shadow-lg">
                    <form asp-action="Index" method="get">
                        <span class="filter-header">Filter by &nbsp; ▾</span>

                        <span class="filter-label">sort by ></span>
                        <select name="sort" class="filter-select" onchange="this.form.submit()">
                            <option value="">-</option>
                            <option value="A to Z">A to Z</option>
                            <option value="Z to A">Z to A</option>
                            <option value="New to Old">New to Old</option>
                            <option value="Old to New">Old to New</option>
                        </select>

                        <span class="filter-label">Subject ></span>
                        <select name="subject" class="filter-select" onchange="this.form.submit()">
                            <option value="">-</option>
                            <option value="IOT">IOT</option>
                        </select>

                        <span class="filter-label">Type ></span>
                        <select name="type" class="filter-select" onchange="this.form.submit()">
                            <option value="">-</option>
                            <option value="Individual">Individual</option>
                            <option value="Group">Group</option>
                        </select>
                    </form>
                </div>
            </div>
        </div>

        <div style="background-color: #444; padding: 25px; border-radius: 30px;">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <a href="@Url.Action("ProjectDetails", "Student", new { title = item.Title })" class="project-link">
                        <div class="project-card">
                            <div class="d-flex justify-content-between">
                                <strong>Project: @item.Title</strong>
                                <span class="btn-purple" style="font-size: 0.8rem;">@item.Status</span>
                            </div>
                            <div>Group: @item.Group</div>
                            <div>Category: @item.Category</div>
                            <div class="small mt-2">@item.Description</div>
                        </div>
                    </a>
                }
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
