@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Forget Password</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body class="login-body">
    <div class="login-container">
        <h1 class="main-title">Forget Password</h1>

        <form asp-action="ForgetPassword" method="post">
            <div class="role-badge">
                <span id="role-student" class="role-item active" onclick="setRole('Student')">Student</span>
                <span class="divider">|</span>
                <span id="role-supervisor" class="role-item" onclick="setRole('Supervisor')">Supervisor</span>
            </div>

            <input type="hidden" name="role" id="selectedRole" value="Student" />

            <div class="input-group">
                <label>Email</label>
                <input type="email" name="email" required />
            </div>

            <button type="submit" class="login-btn">Send Email</button>

            <p><a asp-action="Login" style="color: #ccc; text-decoration: none; font-size: 14px;">Back to Login</a></p>
        </form>

        @if (ViewBag.Message != null)
        {
            <p style="color: #4CAF50; margin-top: 20px;">@ViewBag.Message</p>
        }
    </div>

    <script>
        function setRole(role) {
            document.getElementById('selectedRole').value = role;
            document.getElementById('role-student').classList.remove('active');
            document.getElementById('role-supervisor').classList.remove('active');
            if(role === 'Student') document.getElementById('role-student').classList.add('active');
            if(role === 'Supervisor') document.getElementById('role-supervisor').classList.add('active');
        }
    </script>
</body>
</html>