@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #1a1a1a; color: white; padding: 40px; }
        .main-card { background-color: #333333; border-radius: 30px; padding: 30px; }
        .header-bar { background-color: #555555; border-radius: 20px; padding: 15px; margin-bottom: 25px; display: flex; justify-content: space-between; }
        .field-container { background-color: #b3b3b3; border-radius: 15px; padding: 5px 15px; display: flex; justify-content: space-between; align-items: center; color: black; margin-bottom: 10px; }
        .edit-link { color: #5b50b9; cursor: pointer; text-decoration: underline; font-size: 14px; }
        .save-btn { background-color: #5b50b9; color: white; border-radius: 15px; padding: 5px 30px; border: none; cursor: pointer; text-decoration: none; display: inline-block; }
        select { background: none; border: none; width: 100%; }
        .editable-input { border: none; background: transparent; width: 100%; color: black; outline: none; }
    </style>
</head>
<body>
    <div class="container main-card">
        <div class="header-bar">
            <a href="/Supervisor/Dashboard" class="fw-bold fs-4 text-white text-decoration-none">
                &lt; My Account
            </a>
            <a href="/Supervisor/Dashboard" class="save-btn">Save</a>
        </div>

        <div class="row">
            <div class="col-12">
                <label>Full Name</label>
                <div class="field-container">
                    <input type="text" value="Prof. Venuja" class="editable-input" readonly> 
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>
            
            <div class="col-md-6">
                <label>Faculty</label>
                <div class="field-container">
                    <select>
                        <option style="color: purple;">Computing</option>
                        <option>Business</option>
                        <option>Engineering</option>
                        <option>Science</option>
                    </select>
                </div>
            </div>
            
            <div class="col-md-6">
                <label>Lecturer ID</label>
                <div class="field-container">
                    <input type="text" value="SUP-9912" class="editable-input" readonly> 
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>
            
            <div class="col-12"><label>Expertise</label><div class="field-container"><select><option>IOT</option><option>AI</option></select></div></div>
            
            <div class="col-12">
                <label>NIC</label>
                <div class="field-container">
                    <input type="text" value="951234567V" class="editable-input" readonly> 
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>
            
            <div class="col-12">
                <label>Keywords</label>
                <div class="field-container" style="height: 80px;">
                    <textarea class="editable-input" readonly style="height: 60px; resize: none;">Smart Home, Sensors</textarea>
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>

            <div class="col-md-6">
                <label>Gender</label>
                <div class="field-container">
                    <input type="text" value="Male" class="editable-input" readonly> 
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>
            
            <div class="col-md-6">
                <label>Contact Number</label>
                <div class="field-container">
                    <input type="text" value="0718545239" class="editable-input" readonly> 
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>
            
            <div class="col-md-6">
                <label>Email</label>
                <div class="field-container">
                    <input type="text" value="venuja@uni.ac.lk" class="editable-input" readonly> 
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>
            
            <div class="col-md-6">
                <label>Password</label>
                <div class="field-container">
                    <input type="password" value="password123" class="editable-input" readonly> 
                    <span class="edit-link" onclick="enableEdit(this)">Edit</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        function enableEdit(element) {
            const container = element.parentElement;
            const input = container.querySelector('input, textarea');
            
            if (input.hasAttribute('readonly')) {
                input.removeAttribute('readonly');
                input.focus();
                element.innerText = "Done";
                element.style.color = "#28a745"; 
            } else {
                input.setAttribute('readonly', 'true');
                element.innerText = "Edit";
                element.style.color = "#5b50b9"; 
            }
        }
    </script>
</body>
</html>