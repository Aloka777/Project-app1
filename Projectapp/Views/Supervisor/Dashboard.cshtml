@model IEnumerable<Projectapp.Models.ProjectProposal>
@{
    Layout = null;
    var supervisor = ViewBag.Supervisor as Projectapp.Models.ApplicationUser;
    var faculties = ViewBag.Faculties as IEnumerable<Projectapp.Models.Faculty>;
    var masterKeywords = ViewBag.MasterKeywords as IEnumerable<Projectapp.Models.MasterKeyword>;
    var currentKeywords = (supervisor.Keywords ?? "").Split(',').ToList();
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/all.min.css" />
    <style>
        body { background: #000; color: white; font-family: 'Segoe UI', sans-serif; }
        .sidebar { width: 260px; height: 100vh; background: #0a0a0a; position: fixed; padding: 25px; border-right: 1px solid #222; }
        .main-content { margin-left: 260px; padding: 40px; }
        .card-project { background: #141414; border: 1px solid #333; border-radius: 12px; padding: 20px; transition: 0.2s; height: 100%; position: relative; }
        .card-project:hover { border-color: #5e4bb6; background: #1a1a1a; }
        .btn-purple { background: #5e4bb6; color: white; border: none; border-radius: 8px; padding: 8px 20px; font-weight: bold; }
        .nav-link-custom { display: block; padding: 12px 15px; color: #777; text-decoration: none; border-radius: 10px; margin-bottom: 5px; }
        .nav-link-custom:hover, .nav-link-custom.active { background: #5e4bb6; color: white; }
        .keyword-tag { display: inline-block; padding: 5px 12px; margin: 3px; background: #222; border-radius: 15px; cursor: pointer; font-size: 0.8rem; border: 1px solid #444; }
        .keyword-tag.active { background: #5e4bb6; border-color: #5e4bb6; }
        .form-control, .form-select { background: #111; border: 1px solid #333; color: white; border-radius: 8px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h3 class="fw-bold mb-5">Supervisor</h3>
        <a href="#" class="nav-link-custom active"><i class="fas fa-grid-2 me-2"></i> Dashboard</a>
        <a href="@Url.Action("Interests", new { email = supervisor.Email })" class="nav-link-custom"><i class="fas fa-heart me-2"></i> Interests</a>
        <a href="#" class="nav-link-custom" data-bs-toggle="modal" data-bs-target="#profileModal"><i class="fas fa-user-edit me-2"></i> Edit Profile</a>
        <div style="position: absolute; bottom: 30px; width: 210px;">
            <a href="@Url.Action("Login", "Account")" class="text-danger text-decoration-none"><i class="fas fa-sign-out-alt me-2"></i> Logout</a>
        </div>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold">Discover Projects</h2>
                <span class="text-secondary small">Showing projects matching: <b>@supervisor.Keywords</b></span>
            </div>
            <form method="get" class="d-flex gap-2">
                <input type="hidden" name="email" value="@supervisor.Email" />
                <select name="typeFilter" class="form-select w-auto">
                    <option value="">All Types</option>
                    <option value="Individual">Individual</option>
                    <option value="Group">Group</option>
                </select>
                <select name="sortBy" class="form-select w-auto">
                    <option value="">Sort By</option>
                    <option value="a-z">A-Z</option>
                    <option value="newest">Newest</option>
                </select>
                <button type="submit" class="btn btn-purple">Filter</button>
            </form>
        </div>

        <div class="row g-4">
            @foreach (var p in Model) {
                <div class="col-md-6">
                    <div class="card-project">
                        <div class="d-flex justify-content-between">
                            <h5 class="fw-bold text-white mb-1">@p.Title</h5>
                            <form asp-action="AddToInterests" method="post">
                                <input type="hidden" name="projectId" value="@p.Id" />
                                <input type="hidden" name="supervisorEmail" value="@supervisor.Email" />
                                <button type="submit" class="btn btn-sm btn-success px-3">ADD</button>
                            </form>
                        </div>
                        <div class="mb-2">
                            <span class="badge bg-dark border border-secondary text-secondary">@p.ProjectType</span>
                            <span class="text-primary small ms-2">@p.Category</span>
                        </div>
                        <p class="small text-secondary mb-0">@p.Abstract</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="modal fade" id="profileModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content bg-dark border-secondary text-white" style="border-radius: 20px;">
                <form asp-action="UpdateProfile" method="post">
                    <input type="hidden" name="Id" value="@supervisor.Id" />
                    <div class="modal-header border-0"><h5>Update Professional Details</h5></div>
                    <div class="modal-body px-4">
                        <div class="row g-3">
                            <div class="col-md-6"><label class="small mb-1">Full Name</label><input type="text" name="FullName" value="@supervisor.FullName" class="form-control" /></div>
                            <div class="col-md-6">
                                <label class="small mb-1">Faculty</label>
                                <select name="Faculty" class="form-select">
                                    @foreach(var f in faculties) { <option value="@f.Name" selected="@(supervisor.Faculty == f.Name)">@f.Name</option> }
                                </select>
                            </div>
                            <div class="col-md-4"><label class="small mb-1">Lecture ID</label><input type="text" name="AcademicId" value="@supervisor.AcademicId" class="form-control" /></div>
                            <div class="col-md-4"><label class="small mb-1">NIC</label><input type="text" name="NIC" value="@supervisor.NIC" class="form-control" /></div>
                            <div class="col-md-4">
                                <label class="small mb-1">Gender</label>
                                <select name="Gender" class="form-select">
                                    <option value="Male" selected="@(supervisor.Gender=="Male")">Male</option>
                                    <option value="Female" selected="@(supervisor.Gender=="Female")">Female</option>
                                </select>
                            </div>
                            <div class="col-md-6"><label class="small mb-1">Contact</label><input type="text" name="ContactNumber" value="@supervisor.ContactNumber" class="form-control" /></div>
                            <div class="col-md-6"><label class="small mb-1">Email</label><input type="email" name="Email" value="@supervisor.Email" class="form-control" readonly /></div>
                            <div class="col-12 mt-4">
                                <label class="fw-bold mb-2">Expertise Keywords (Manage Tags)</label>
                                <div class="p-3 bg-black border border-secondary rounded">
                                    @foreach(var k in masterKeywords) {
                                        <div class="keyword-tag @(currentKeywords.Contains(k.Name) ? "active" : "")" 
                                             onclick="toggleTag(this, '@k.Name')">@k.Name</div>
                                    }
                                </div>
                                <select name="selectedKeywords" id="tagSelect" multiple hidden>
                                    @foreach(var k in currentKeywords) { <option value="@k" selected>@k</option> }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4">
                        <button type="submit" class="btn btn-purple w-100">Save Professional Profile</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleTag(el, val) {
            const select = document.getElementById('tagSelect');
            el.classList.toggle('active');
            if (el.classList.contains('active')) {
                const opt = new Option(val, val, true, true);
                select.add(opt);
            } else {
                for (let i=0; i<select.options.length; i++) {
                    if (select.options[i].value === val) { select.remove(i); break; }
                }
            }
        }
    </script>
</body>
</html>