@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Supervisor Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #333333; color: white; font-family: sans-serif; padding: 20px; }
        
        /* Main Container */
        .dashboard-card { background-color: #555555; border-radius: 30px; padding: 30px; margin-bottom: 20px; position: relative; }
        
        /* Buttons */
        .btn-purple { background-color: #5b50b9; color: white; border-radius: 20px; padding: 10px 25px; border: none; }
        .btn-purple:hover { background-color: #4a4099; color: white; }
        .btn-add { background-color: #5b50b9; color: white; border-radius: 12px; width: 80px; float: right; }

        /* Project Cards */
        .project-list-container { background-color: #444444; border-radius: 30px; padding: 20px; }
        .project-item { background-color: #cccccc; color: black; border-radius: 20px; padding: 15px; margin-bottom: 15px; }

        /* Filter Dropdown/Modal */
        .filter-box { 
            display: none; position: absolute; right: 20px; top: 120px; 
            background-color: #d1d1d1; color: black; border-radius: 25px; 
            padding: 20px; width: 250px; z-index: 100; box-shadow: 0 10px 20px rgba(0,0,0,0.5);
        }
        .filter-input { background-color: #a0a0a0; border: none; border-radius: 10px; margin-bottom: 10px; width: 100%; padding: 5px; }
    </style>
</head>
<body>

<div class="container">
    <div class="dashboard-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="display-6 fw-bold">Welcome</h1>
                <p>2026.04.13</p>
            </div>
            <div>
                <a href="/Supervisor/Interests" class="btn btn-purple">Interests</a>
                <a href="/Supervisor/MyAccount" class="btn btn-purple">Account</a>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between mb-3">
        <button class="btn btn-purple">Projects</button>
        <button class="btn btn-purple" onclick="toggleFilter()">Filter ⌵</button>
    </div>

    <div id="filterBox" class="filter-box">
        <h6>Filter by ⌵</h6>
        <p class="small mb-1">sort by ></p>
        <input type="text" class="filter-input" placeholder="date">
        <input type="text" class="filter-input" placeholder="A to Z">
        <p class="small mb-1">Area ></p>
        <input type="text" class="filter-input" placeholder="-">
        <p class="small mb-1">Type ></p>
        <input type="text" class="filter-input" placeholder="Individual">
        <button class="btn btn-purple w-100" onclick="toggleFilter()">Filter</button>
    </div>

    <div class="project-list-container">
        <div class="project-item">
            <button class="btn btn-add">ADD</button>
            <h5 class="fw-bold">Project: Housing meter</h5>
            <p class="mb-0">Group: 69</p>
            <p class="mb-0">Category: IOT</p>
            <p class="small text-muted mt-2">Description: cascmknsknvkndljkbnsdm klscvkjdcnvlkfdsmn ksdcnj... </p>
            <p class="small">Date: 2026.04.13</p>
        </div>

        <div class="project-item">
            <button class="btn btn-add">ADD</button>
            <h5 class="fw-bold">Project: Monitoring system</h5>
            <p class="mb-0">Group: Individual</p>
            <p class="mb-0">Category: IOT</p>
            <p class="small text-muted mt-2">Description: cascmknsknvkndljkbnsdm klscvkjdcnvlkfdsmn ksdcnj... </p>
            <p class="small">Date: 2026.04.12</p>
        </div>
    </div>
</div>

<script>
    function toggleFilter() {
        var box = document.getElementById("filterBox");
        box.style.display = (box.style.display === "block") ? "none" : "block";
    }
</script>

</body>
</html>