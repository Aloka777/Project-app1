@{
    Layout = null;
}<!DOCTYPE html><html lang="en"><head>
    <meta charset="UTF-8">
    <title>Interests</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #333333; color: white; font-family: sans-serif; padding: 40px; }
        
        /* Main Gray Container */
        .main-container { background-color: #555555; border-radius: 30px; padding: 40px; min-height: 80vh; }

        /* Header Bar */
        .header-bar { background-color: #777777; border-radius: 25px; padding: 20px; margin-bottom: 30px; display: flex; align-items: center; }
        .back-link { color: white; text-decoration: none; font-size: 24px; font-weight: bold; margin-right: 10px; cursor: pointer; }

        /* Inner Content Box */
        .content-box { background-color: #444444; border-radius: 30px; padding: 30px; }

        /* Project Card - Made Clickable */
        .project-card { 
            background-color: #cccccc; 
            color: black; 
            border-radius: 25px; 
            padding: 20px; 
            margin-bottom: 20px; 
            position: relative; 
            cursor: pointer; 
            transition: 0.2s;
            display: block;
            text-decoration: none;
        }
        .project-card:hover { background-color: #bbbbbb; }
        
        /* Buttons */
        .btn-purple { background-color: #5b50b9; color: white; border-radius: 15px; border: none; padding: 5px 20px; font-weight: bold; transition: 0.3s; }
        .btn-purple:hover { background-color: #4a4099; transform: scale(1.05); }
        .status-badge { display: none; background-color: #28a745; color: white; padding: 5px 15px; border-radius: 15px; font-weight: bold; }
    </style></head><body><div class="container main-container">
    <div class="header-bar">
        <a href="/Supervisor/Dashboard" class="back-link">&lt;Interests</a>
    </div>

    <div class="content-box">
        <a href="/Supervisor/ProjectDetails/1" class="project-card" id="proj-1">
            <div class="float-end">
                <button class="btn-purple me-2" onclick="event.preventDefault(); event.stopPropagation(); acceptProject(1)">Accept</button>
                <button class="btn-purple" onclick="event.preventDefault(); event.stopPropagation(); removeProject(1)">Remove</button>
                <span id="badge-1" class="status-badge">Accepted ✓</span>
            </div>
            <h5 class="fw-bold" style="color: black;">Project: Housing meter</h5>
            <p class="mb-0">Group: 69</p>
            <p class="mb-0">Category: IOT</p>
            <p class="small text-muted mt-2">cascmknsknvkndljkbnsdm klscvkjdcnvlkfdsmn ksdcnjvl kdfmvezfjdnvbldkn</p>
        </a>

        </div></div><script>
    // Function to handle "Accept"    
    function acceptProject(id) {
        const card = document.getElementById(`proj-${id}`);
        const btns = card.querySelectorAll('.btn-purple');
        btns.forEach(b => b.style.display = 'none');
        document.getElementById(`badge-${id}`).style.display = 'inline-block';
    }

    // Function to handle "Remove"    
    function removeProject(id) {
        if(confirm("Are you sure you want to remove this project?")) {
            const card = document.getElementById(`proj-${id}`);
            card.style.transition = "0.4s";
            card.style.opacity = "0";
            card.style.transform = "translateX(50px)";
            setTimeout(() => card.remove(), 400);
        }
    }</script></body></html>