@model IEnumerable<Projectapp.Models.SupervisorInterest>
@{
    Layout = null;
    var supervisor = ViewBag.Supervisor as Projectapp.Models.ApplicationUser;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #000; color: white; font-family: sans-serif; }
        .sidebar { width: 260px; height: 100vh; background: #0a0a0a; position: fixed; padding: 25px; border-right: 1px solid #222; }
        .main-content { margin-left: 260px; padding: 40px; }
        .card-interest { background: #141414; border: 1px solid #333; border-radius: 12px; padding: 25px; margin-bottom: 20px; }
        .btn-purple { background: #5e4bb6; color: white; border: none; border-radius: 8px; padding: 8px 20px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h3 class="fw-bold mb-5">Supervisor</h3>
        <a href="@Url.Action("Dashboard", new { email = supervisor.Email })" style="display:block; padding:12px; color:#777; text-decoration:none;">Dashboard</a>
        <a href="#" style="display:block; padding:12px; background:#5e4bb6; color:white; border-radius:10px; text-decoration:none;">Interests</a>
    </div>

    <div class="main-content">
        <h2>Shortlisted Projects</h2>
        <div class="mt-4">
            @foreach (var item in Model) {
                <div class="card-interest">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h4 class="fw-bold mb-1">@item.Project?.Title</h4>
                            <p class="text-primary small mb-2">@item.Project?.ProjectType | @item.Project?.Category</p>
                            <p class="text-secondary small mb-3">@item.Project?.Abstract</p>
                            <span class="badge @(item.Status == "Accepted" ? "bg-success" : "bg-warning text-dark")">@item.Status</span>
                        </div>
                        <form asp-action="ProcessInterest" method="post">
                            <input type="hidden" name="interestId" value="@item.Id" />
                            <div class="d-flex flex-column gap-2">
                                @if (item.Status != "Accepted") {
                                    <button type="submit" name="action" value="Accept" class="btn btn-purple">Accept</button>
                                }
                                <button type="submit" name="action" value="Remove" class="btn btn-outline-danger">Remove</button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</body>
</html>