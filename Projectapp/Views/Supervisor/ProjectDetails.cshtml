@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #1a1a1a; color: white; font-family: sans-serif; padding: 40px; }
        .main-card { background-color: #333333; border-radius: 30px; padding: 30px; position: relative; }
        .header-bar { background-color: #555555; border-radius: 20px; padding: 15px; margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center; }
        .back-btn { color: white; text-decoration: none; font-size: 20px; font-weight: bold; }
        .input-box { background-color: #b3b3b3; border-radius: 15px; height: 35px; margin-bottom: 15px; border: none; width: 100%; }
        .large-box { height: 150px; }
        label { font-weight: bold; margin-bottom: 5px; display: block; }
        .btn-accept { background-color: #5b50b9; color: white; border-radius: 15px; padding: 5px 30px; border: none; font-weight: bold; }
        .status-accepted { display: none; color: #28a745; font-weight: bold; border: 2px solid #28a745; padding: 5px 15px; border-radius: 15px; }
    </style>
</head>
<body>
    <div class="container main-card">
        <div class="header-bar">
            <a href="/Supervisor/Interests" class="back-btn">&lt; Project</a>
            <button id="acceptBtn" class="btn-accept" onclick="markAccepted()">Accept</button>
            <span id="statusLabel" class="status-accepted">Accepted ✓</span>
        </div>

        <label>Project Title</label><div class="input-box"></div>
        <label>Student Name</label><div class="input-box"></div>
        <label>Technical Stack</label><div class="input-box"></div>
        <label>Abstract</label><div class="input-box"></div>

        <div class="row">
            <div class="col-md-6">
                <label>Proposal</label>
                <div class="input-box large-box"></div>
            </div>
            <div class="col-md-6">
                <label>Type</label>
                <div class="d-flex align-items-center">
                    <span class="me-2">Individual</span> <input type="radio" name="type" class="me-3">
                    <span class="me-2">Group</span> <input type="radio" name="type">
                </div>
                <div class="input-box large-box mt-3"></div>
            </div>
        </div>
    </div>

    <script>
        function markAccepted() {
            document.getElementById('acceptBtn').style.display = 'none';
            document.getElementById('statusLabel').style.display = 'inline-block';
        }
    </script>
</body>
</html>